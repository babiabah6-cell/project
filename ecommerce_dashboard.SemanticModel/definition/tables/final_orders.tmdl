	column 'Delay Status' =
			
			IF(
			    final_orders[delivery_delay_days] > 0,
			    "Delayed",
			    "On Time"
			)
		lineageTag: c0ab44c7-4379-4f64-b236-1ec844fbab68
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Avg Delay Days' = ```
			
			AVERAGEX(
			    'final_orders', 
			    IF('final_orders'[delivery_delay_days] < 0, 0, 'final_orders'[delivery_delay_days])
			)
			
			```
		lineageTag: d65594b3-316a-46f8-b7f5-55b6c3be8ce3
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Delivery Bucket' =
			
			SWITCH(
			    TRUE(),
			    final_orders[delivery_time_days] <= 5, "0-5 Days",
			    final_orders[delivery_time_days] <= 10, "6-10 Days",
			    final_orders[delivery_time_days] <= 20, "11-20 Days",
			    final_orders[delivery_time_days] <= 30, "21-30 Days",
			    "30+ Days"
			)
		lineageTag: 3fd9631d-f462-4336-bf87-b5a167d243ad
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

