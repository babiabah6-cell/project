table final_orders
	lineageTag: cc2434ab-f058-4a8a-a658-3ea04e8ea093

	measure '% Delayed Orders' =
			
			DIVIDE(
			    CALCULATE(COUNTROWS(final_orders), final_orders[delivery_delay_days] > 0),
			    COUNTROWS(final_orders)
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: abda45f6-542d-4b34-89c0-d5b9c2dded1a

	measure 'Total Orders' = DISTINCTCOUNT(final_orders[order_id])
		formatString: 0
		lineageTag: b136f2bc-1cb3-472e-96ea-2e57e831d1a7

	measure 'Total Customers' = DISTINCTCOUNT(final_orders[customer_unique_id])
		formatString: 0
		lineageTag: e502f21b-427d-4851-879a-49f30e480156

	measure 'Avg Delivery Time' = AVERAGE(final_orders[delivery_time_days])
		formatString: 0.0
		lineageTag: 6719a623-18b3-476f-8006-f5a6541136e3

	measure 'Total Revenue' = SUM(final_orders[total_order_value])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: c9056c61-004e-49dd-aaee-9fddad0c9b89

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure Avg_Delivery_Delay_days = AVERAGE(final_orders[delivery_delay_days])
		formatString: 0.0
		lineageTag: faf8f8eb-905c-46f3-be6c-2efa17370710

	measure 'Avg Review Score' =
			
			AVERAGE(final_orders[review_score])
		formatString: 0.0
		lineageTag: 7b7db8e4-f840-4bcf-95be-f389e3898bad

	measure 'Champions Customers' =
			
			CALCULATE(
			    DISTINCTCOUNT(final_orders_rfm[customer_unique_id]),
			    final_orders_rfm[Customer_Segment] = "Champions"
			)
		formatString: 0
		lineageTag: fcd38a91-ffa0-402f-8e9e-e161d1e4ddd6

	measure 'Loyal Customers' =
			
			CALCULATE(
			    DISTINCTCOUNT(final_orders_rfm[customer_unique_id]),
			    final_orders_rfm[Customer_Segment] = "Loyal Customers"
			)
		formatString: 0
		lineageTag: d9594777-f641-4c55-8d2f-29cebc5fb0b0

	measure 'At Risk Customers' =
			
			CALCULATE(
			    DISTINCTCOUNT(final_orders_rfm[customer_unique_id]),
			    final_orders_rfm[Customer_Segment] = "At Risk"
			)
		formatString: 0
		lineageTag: 29aff3bb-9f0b-46ed-94fd-d09c82f24ab7

