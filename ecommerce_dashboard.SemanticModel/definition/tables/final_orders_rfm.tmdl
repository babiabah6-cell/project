table final_orders_rfm
	lineageTag: 69fdb895-c25f-4f8a-87f6-700717fe9af9

	measure 'Segment Color' = ```
			
			VAR CurrentSegment = SELECTEDVALUE('final_orders_rfm'[Customer_Segment])
			RETURN
			SWITCH( CurrentSegment,
			    "Champions", "#2A9D8F",         -- Teal Green
			    "Loyal Customers", "#264653",   -- Deep Navy
			    "At Risk", "#E76F51",           -- Burnt Orange
			    "Can't Lose Them", "#A8201A",   -- Deep Red
			    "Hibernating", "#8D99AE",       -- Slate Gray
			    "New Customers", "#E9C46A",     -- Saffron Yellow
			    "#D1D1D1"                       -- Default Light Gray
			)
			
			
			
			```
