	column M_Score
		dataType: int64
		formatString: 0
		lineageTag: 55da79fb-7c33-47bb-9bd9-f6eae5446163
		summarizeBy: sum
		sourceColumn: M_Score

		annotation SummarizationSetBy = Automatic

	column Customer_Segment = ```
			
			VAR R = 'final_orders_rfm'[R_Score]
			VAR F = 'final_orders_rfm'[F_Score]
			VAR M = 'final_orders_rfm'[M_Score]
			
			RETURN
			SWITCH(
			    TRUE(),
			
			    /* 1. CHAMPIONS: Best customers across all metrics */
			    R >= 4 && F >= 4 && M >= 4, "Champions",
			
			    /* 2. CAN'T LOSE THEM: High frequency but haven't bought in a long time */
			    R = 1 && F >= 4, "Can't Lose Them",
			
			    /* 3. AT RISK: Were frequent spenders but declining activity */
			    R <= 2 && F >= 3, "At Risk",
			
			    /* 4. LOYAL CUSTOMERS: Steady, frequent purchasers */
			    R >= 3 && F >= 3, "Loyal Customers",
			
			    /* 5. NEW CUSTOMERS: High recency, but only 1 purchase (The Olist majority) */
			    R >= 4 && F = 1, "New Customers",
			
			    /* 6. POTENTIAL LOYALISTS: Recent customers with some growth potential */
			    R >= 4 && F <= 3, "Potential Loyalists",
			
			    /* 7. HIBERNATING: Low scores on all fronts; long-term inactivity */
			    R <= 2 && F <= 2, "Hibernating",
			
			    /* DEFAULT: Anything that didn't fit the above */
			    "Need Attention"
			)
			
			```
		lineageTag: a03d96da-0e90-460c-aff9-bde231070909
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

